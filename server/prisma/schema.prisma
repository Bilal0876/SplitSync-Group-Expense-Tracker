generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model expense_splits {
  id         String    @id @default(uuid())
  expense_id String?
  user_id    String?
  share      Decimal   @db.Decimal(12, 2)
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  expenses   expenses? @relation(fields: [expense_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users?    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model expenses {
  id             String           @id @default(uuid())
  description    String
  amount         Decimal          @db.Decimal(12, 2)
  payer_id       String?
  group_id       String?
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  updated_at     DateTime         @default(now()) @updatedAt @db.Timestamp(6)
  is_deleted     Boolean          @default(false)
  expense_splits expense_splits[]
  groups         groups?          @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users          users?           @relation(fields: [payer_id], references: [id], onUpdate: NoAction)
}

model group_members {
  group_id  String
  user_id   String
  joined_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp(6)
  groups    groups    @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users     users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([group_id, user_id])
}

model groups {
  id            String          @id @default(uuid())
  name          String          @db.VarChar(100)
  created_by    String?
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  updated_at    DateTime        @default(now()) @updatedAt @db.Timestamp(6)
  is_deleted    Boolean         @default(false)
  expenses      expenses[]
  group_members group_members[]
  settlements   settlements[]
  invitations   invitations[]
  creator       users?          @relation("GroupCreator", fields: [created_by], references: [id], onUpdate: NoAction)
}

model settlements {
  id                                   String    @id @default(uuid())
  sender_id                            String?
  receiver_id                          String?
  group_id                             String?
  amount                               Decimal   @db.Decimal(12, 2)
  settled_at                           DateTime? @default(now()) @db.Timestamp(6)
  updated_at                           DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  is_deleted                           Boolean   @default(false)
  groups                               groups?   @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_settlements_receiver_idTousers users?    @relation("settlements_receiver_idTousers", fields: [receiver_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_settlements_sender_idTousers   users?    @relation("settlements_sender_idTousers", fields: [sender_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model users {
  id                                         String           @id @default(uuid())
  username                                   String           @unique @db.VarChar(50)
  email                                      String           @unique @db.VarChar(100)
  password_hash                              String
  created_at                                 DateTime?        @default(now()) @db.Timestamp(6)
  updated_at                                 DateTime         @default(now()) @updatedAt @db.Timestamp(6)
  is_deleted                                 Boolean          @default(false)
  expense_splits                             expense_splits[]
  expenses                                   expenses[]
  group_members                              group_members[]
  settlements_settlements_receiver_idTousers settlements[]    @relation("settlements_receiver_idTousers")
  settlements_settlements_sender_idTousers   settlements[]    @relation("settlements_sender_idTousers")
  created_groups                             groups[]         @relation("GroupCreator")
  sent_invitations                           invitations[]    @relation("InvitationSender")
  received_invitations                        invitations[]    @relation("InvitationReceiver")
}

model invitations {
  id         String    @id @default(uuid())
  group_id   String
  user_id    String
  invited_by String
  status     String    @default("pending") @db.VarChar(20) // pending, accepted, rejected
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamp(6)
  
  groups     groups    @relation(fields: [group_id], references: [id], onDelete: Cascade)
  receiver   users     @relation("InvitationReceiver", fields: [user_id], references: [id], onDelete: Cascade)
  sender     users     @relation("InvitationSender", fields: [invited_by], references: [id], onDelete: Cascade)
}
